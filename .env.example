# Copie este arquivo para .env e preencha os valores.
#
#   cp .env.example .env        (Linux/macOS)
#   copy .env.example .env      (Windows / PowerShell: Copy-Item .env.example .env)

# Chave de API do Google Gemini.
# Gere a sua gratuitamente em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Modelo do Gemini a ser usado (opcional). Padrão: gemini-2.5-flash-lite
GEMINI_MODEL=gemini-2.5-flash-lite


# ============================================================
# Providers futuros
# ============================================================
# O projeto atualmente usa Gemini.
# Com mais tempo, seria possível adicionar suporte a outros providers
# usando uma interface comum de LLM e podendo selecionar qual o modelo de LLM utilizar.
#
# OPENAI_API_KEY=
# OPENAI_MODEL=
#
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=